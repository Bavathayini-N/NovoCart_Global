{
  "datasets": [
    {
      "name": "e9f42577",
      "displayName": "Total Revenue (Completed)",
      "queryLines": [
        "SELECT\n",
        "  SUM(line_total_usd) as total_revenue\n",
        "FROM\n",
        "  kpi_datacube\n",
        "WHERE\n",
        "  order_status = 'completed'"
      ],
      "catalog": "novocart_global",
      "schema": "novocart_gold"
    },
    {
      "name": "b9257e9a",
      "displayName": "Revenue by Country",
      "queryLines": [
        "SELECT\n",
        "  country_code,\n",
        "  SUM(line_total_usd) as revenue\n",
        "FROM\n",
        "  kpi_datacube\n",
        "GROUP BY\n",
        "  country_code\n",
        "ORDER BY\n",
        "  revenue DESC"
      ],
      "catalog": "novocart_global",
      "schema": "novocart_gold"
    },
    {
      "name": "166a9c46",
      "displayName": "Revenue by Channel",
      "queryLines": [
        "SELECT\n",
        "  channel,\n",
        "  SUM(line_total_usd) as revenue\n",
        "FROM\n",
        "  kpi_datacube\n",
        "GROUP BY\n",
        "  channel\n",
        "ORDER BY\n",
        "  revenue DESC"
      ],
      "catalog": "novocart_global",
      "schema": "novocart_gold"
    },
    {
      "name": "49d7c35b",
      "displayName": "Order Metrics",
      "queryLines": [
        "SELECT\n",
        "  COUNT(DISTINCT\n",
        "    CASE\n",
        "      WHEN order_status = 'completed' THEN order_id\n",
        "    END\n",
        "  ) as completed_orders,\n",
        "  COUNT(DISTINCT order_id) as total_orders,\n",
        "  COUNT(DISTINCT\n",
        "    CASE\n",
        "      WHEN order_status = 'completed' THEN order_id\n",
        "    END\n",
        "  )\n",
        "    / COUNT(DISTINCT order_id) as completed_rate\n",
        "FROM\n",
        "  kpi_datacube"
      ],
      "catalog": "novocart_global",
      "schema": "novocart_gold"
    },
    {
      "name": "e7af037a",
      "displayName": "Average Order Value",
      "queryLines": [
        "SELECT\n",
        "  SUM(order_total) / COUNT(*) as avg_order_value\n",
        "FROM\n",
        "  (\n",
        "    SELECT\n",
        "      order_id,\n",
        "      SUM(line_total_usd) as order_total\n",
        "    FROM\n",
        "      kpi_datacube\n",
        "    GROUP BY\n",
        "      order_id\n",
        "  )"
      ],
      "catalog": "novocart_global",
      "schema": "novocart_gold"
    },
    {
      "name": "11ad6061",
      "displayName": "Top 5 Products by Revenue",
      "queryLines": [
        "SELECT\n",
        "  product_id,\n",
        "  product_name,\n",
        "  SUM(line_total_usd) as revenue\n",
        "FROM\n",
        "  kpi_datacube\n",
        "GROUP BY\n",
        "  product_id,\n",
        "  product_name\n",
        "ORDER BY\n",
        "  revenue DESC\n",
        "LIMIT 5"
      ],
      "catalog": "novocart_global",
      "schema": "novocart_gold"
    },
    {
      "name": "efbcd071",
      "displayName": "Active Customers",
      "queryLines": [
        "SELECT\n",
        "  COUNT(DISTINCT customer_id) as active_customers\n",
        "FROM\n",
        "  kpi_datacube"
      ],
      "catalog": "novocart_global",
      "schema": "novocart_gold"
    },
    {
      "name": "83b7ff2e",
      "displayName": "Customer Acquisition Trend",
      "queryLines": [
        "SELECT\n",
        "  year,\n",
        "  month,\n",
        "  COUNT(DISTINCT customer_id) as new_customers\n",
        "FROM\n",
        "  kpi_datacube\n",
        "WHERE\n",
        "  year != 1900\n",
        "GROUP BY\n",
        "  year,\n",
        "  month\n",
        "ORDER BY\n",
        "  year,\n",
        "  month"
      ],
      "columns": [
        {
          "displayName": "Period",
          "description": "Year-Month period formatted as YYYY-MM",
          "expression": "CONCAT(CAST(`year` AS STRING), '-', LPAD(CAST(`month` AS STRING), 2, '0'))"
        }
      ],
      "catalog": "novocart_global",
      "schema": "novocart_gold"
    },
    {
      "name": "2c68f158",
      "displayName": "Data Quality Score",
      "queryLines": [
        "SELECT\n",
        "  COUNT(\n",
        "    CASE\n",
        "      WHEN customer_id != 'UNKNOWN' THEN 1\n",
        "    END\n",
        "  )\n",
        "    / COUNT(*) as data_quality_score\n",
        "FROM\n",
        "  kpi_datacube"
      ],
      "catalog": "novocart_global",
      "schema": "novocart_gold"
    }
  ],
