{
  "datasets": [
    {
      "name": "5a37324c",
      "displayName": "Total Revenue",
      "queryLines": [
        "SELECT\n",
        "  SUM(line_total_usd) AS total_revenue\n",
        "FROM\n",
        "  novocart_global.novocart_gold.fact_sales"
      ]
    },
    {
      "name": "039adc56",
      "displayName": "Completed Order Count",
      "queryLines": [
        "SELECT\n",
        "  COUNT(DISTINCT order_id) AS completed_order_count\n",
        "FROM\n",
        "  novocart_global.novocart_gold.fact_sales\n",
        "WHERE\n",
        "  order_status = 'completed'"
      ]
    },
    {
      "name": "81fcd5e1",
      "displayName": "Completed Order Rate",
      "queryLines": [
        "SELECT\n",
        "  COUNT(DISTINCT\n",
        "    CASE\n",
        "      WHEN order_status = 'completed' THEN order_id\n",
        "    END\n",
        "  )\n",
        "    * 1.0\n",
        "    / COUNT(DISTINCT order_id) AS completed_order_rate\n",
        "FROM\n",
        "  novocart_global.novocart_gold.fact_sales"
      ]
    },
    {
      "name": "ced0cd0d",
      "displayName": "Average Order Value",
      "queryLines": [
        "SELECT\n",
        "  SUM(line_total_usd) / COUNT(DISTINCT order_id) AS avg_order_value\n",
        "FROM\n",
        "  novocart_global.novocart_gold.fact_sales"
      ]
    },
    {
      "name": "134f3f01",
      "displayName": "Active Customers Count",
      "queryLines": [
        "SELECT\n",
        "  COUNT(DISTINCT c.customer_id) AS active_customers_count\n",
        "FROM\n",
        "  novocart_global.novocart_gold.fact_sales f\n",
        "    JOIN novocart_global.novocart_gold.dim_customer c\n",
        "      ON f.customer_key = c.customer_key\n",
        "WHERE\n",
        "  c.customer_id != 'UNKNOWN'"
      ]
    },
    {
      "name": "ed7e4399",
      "displayName": "Data Quality Score",
      "queryLines": [
        "SELECT\n",
        "  COUNT(DISTINCT\n",
        "    CASE\n",
        "      WHEN c.customer_id != 'UNKNOWN' THEN f.order_item_id\n",
        "    END\n",
        "  )\n",
        "    * 1.0\n",
        "    / COUNT(*) AS data_quality_score\n",
        "FROM\n",
        "  novocart_global.novocart_gold.fact_sales f\n",
        "    JOIN novocart_global.novocart_gold.dim_customer c\n",
        "      ON f.customer_key = c.customer_key"
      ]
    },
    {
      "name": "439b49ed",
      "displayName": "Revenue by Country",
      "queryLines": [
        "SELECT\n",
        "  c.country_code,\n",
        "  SUM(f.line_total_usd) AS revenue\n",
        "FROM\n",
        "  novocart_global.novocart_gold.fact_sales f\n",
        "    JOIN novocart_global.novocart_gold.dim_country c\n",
        "      ON f.country_key = c.country_key\n",
        "GROUP BY\n",
        "  c.country_code"
      ]
    },
    {
      "name": "26d8ad81",
      "displayName": "Revenue by Channel",
      "queryLines": [
        "SELECT\n",
        "  ch.channel,\n",
        "  SUM(f.line_total_usd) AS revenue\n",
        "FROM\n",
        "  novocart_global.novocart_gold.fact_sales f\n",
        "    JOIN novocart_global.novocart_gold.dim_channel ch\n",
        "      ON f.channel_key = ch.channel_key\n",
        "GROUP BY\n",
        "  ch.channel"
      ]
    },
    {
      "name": "88bfd73f",
      "displayName": "Top 5 Products by Revenue",
      "queryLines": [
        "SELECT\n",
        "  p.product_id,\n",
        "  p.product_name,\n",
        "  SUM(f.line_total_usd) AS revenue\n",
        "FROM\n",
        "  novocart_global.novocart_gold.fact_sales f\n",
        "    JOIN novocart_global.novocart_gold.dim_product p\n",
        "      ON f.product_key = p.product_key\n",
        "GROUP BY\n",
        "  p.product_id,\n",
        "  p.product_name\n",
        "ORDER BY\n",
        "  revenue DESC\n",
        "LIMIT 5"
      ]
    },
    {
      "name": "18702f0d",
      "displayName": "Customer Acquisition by Month",
      "queryLines": [
        "SELECT\n",
        "  YEAR(registration_date) AS year,\n",
        "  MONTH(registration_date) AS month,\n",
        "  COUNT(*) AS customer_count\n",
        "FROM\n",
        "  novocart_global.novocart_gold.dim_customer\n",
        "GROUP BY\n",
        "  YEAR(registration_date),\n",
        "  MONTH(registration_date)\n",
        "ORDER BY\n",
        "  year,\n",
        "  month"
      ]
    },
    {
      "name": "3403f88f",
      "displayName": "Data Cube",
      "queryLines": [
        "SELECT\n",
        "  c.country_code,\n",
        "  ch.channel,\n",
        "  p.product_id,\n",
        "  p.product_name,\n",
        "  YEAR(f.order_date) AS year,\n",
        "  MONTH(f.order_date) AS month,\n",
        "  SUM(f.line_total_usd) AS total_revenue,\n",
        "  COUNT(f.order_id) AS order_count,\n",
        "  AVG(f.line_total_usd) AS avg_order_value,\n",
        "  COUNT(DISTINCT cust.customer_id) AS active_customers_count\n",
        "FROM\n",
        "  novocart_global.novocart_gold.fact_sales f\n",
        "    JOIN novocart_global.novocart_gold.dim_country c\n",
        "      ON f.country_key = c.country_key\n",
        "    JOIN novocart_global.novocart_gold.dim_channel ch\n",
        "      ON f.channel_key = ch.channel_key\n",
        "    JOIN novocart_global.novocart_gold.dim_product p\n",
        "      ON f.product_key = p.product_key\n",
        "    JOIN novocart_global.novocart_gold.dim_customer cust\n",
        "      ON f.customer_key = cust.customer_key\n",
        "GROUP BY\n",
        "  c.country_code,\n",
        "  ch.channel,\n",
        "  p.product_id,\n",
        "  p.product_name,\n",
        "  YEAR(f.order_date),\n",
        "  MONTH(f.order_date)"
      ]
    }
  ],
